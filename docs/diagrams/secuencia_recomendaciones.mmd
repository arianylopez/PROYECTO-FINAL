sequenceDiagram
    autonumber
    actor Cliente as "Usuario Registrado\n(Frontend SPA)"
    participant RecsAPI as "Recommendations Module\n(FastAPI)"
    participant Redis as "Redis\n(Cache)"
    participant AuthDB as "AuthDB\n(PostgreSQL)"
    participant Mongo as "MongoDB\n(UGC Store)"
    participant ClickHouse as "ClickHouse\n(Analítica)"
    participant Elastic as "Elasticsearch\n(Catálogo Público)"

    Cliente->>RecsAPI: GET /recommendations/me
    activate RecsAPI
    
    note over RecsAPI, Redis: Fase 1: Verificación de Cache
    RecsAPI->>Redis: GETEX recs:{user_id}
    alt Cache HIT (Éxito)
        Redis-->>RecsAPI: Retorna JSON de recomendaciones
        RecsAPI-->>Cliente: 200 OK (Recomendaciones cargadas al instante)
    else Cache MISS (No existe o expiró)
        Redis-->>RecsAPI: nulo
        
        note over RecsAPI, Mongo: Fase 2: Recolección de Datos de Contexto
        RecsAPI->>Mongo: Buscar ratings_4plus = find(ratings donde score >= 4)
        Mongo-->>RecsAPI: [ {movie_id, genre...}, ... ]
        
        RecsAPI->>Mongo: Buscar watchlist = find(watchlist)
        Mongo-->>RecsAPI: [ {movie_id}, ... ]
        
        RecsAPI->>AuthDB: Leer user.genre_preferences explícitas
        AuthDB-->>RecsAPI: [ "Terror", "Ciencia Ficción" ]
        
        RecsAPI->>Mongo: Buscar dismissed_ids = find(recommendation_feedback action='dismiss')
        Mongo-->>RecsAPI: [ dismissed_movie_id_1, ... ]

        note over RecsAPI, RecsAPI: Fase 3: Cálculo del Algoritmo (Motor)
        RecsAPI->>RecsAPI: Calcular pesos por género: \n5★ -> 1.0, 4★ -> 0.8\nWatchlist -> 0.6\nPreferencias -> +0.3
        RecsAPI->>RecsAPI: Determinar Top 3 géneros dominantes

        note over RecsAPI, Elastic: Fase 4: Búsqueda y Generación de Razón (Explainability)
        RecsAPI->>Elastic: QUERY ES: bool.filter(terms top_genres) \n must_not(dismissed_ids + already_seen_ids)
        activate Elastic
        Elastic-->>RecsAPI: Retorna Top Películas candidatas
        deactivate Elastic

        loop Por cada película recomendada
            RecsAPI->>RecsAPI: Generar "reason.short" y "reason.long" \n(ej: "Porque te gusta Terror y le diste 5★ a 'It'")
        end

        note over RecsAPI, Redis: Fase 5: Guardado y Respuesta
        RecsAPI->>Redis: SETEX recs:{user_id} 600 {json_data} (Cache por 10 min)
        RecsAPI-->>Cliente: 200 OK (Nuevas recomendaciones personalizadas)
    end
    deactivate RecsAPI

    note over Cliente, ClickHouse: Escenario Alternativo: Fallback de Usuario Nuevo
    opt Si el motor detecta que el usuario no tiene historial de consumo
        RecsAPI->>ClickHouse: QUERY: Top 10 por order.completed en últimos 7 días
        ClickHouse-->>RecsAPI: Retorna Tendencias Populares
        RecsAPI-->>Cliente: 200 OK (Sección "Tendencias esta semana")
    end
