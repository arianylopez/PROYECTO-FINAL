<div class="auth-layout">
  <div class="auth-layout__sidebar">
    <button id="go-back-btn" data-navigate="/login" class="auth-form__btn-back">
      Volver al Login
    </button>

    <form class="auth-form" id="forgot-password-form" novalidate>
      
      <div class="auth-form__header">
        <div class="auth-form__logo">
          <svg class="auth-form__logo-icon" width="28" height="28" viewBox="0 0 24 24" fill="currentColor">
            <path d="M22 10V6a2 2 0 0 0-2-2H4a2 2 0 0 0-2 2v4c1.1 0 2 .9 2 2s-.9 2-2 2v4a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2v-4c-1.1 0-2-.9-2-2s.9-2 2-2z"/>
          </svg>
          <span class="auth-form__logo-text">CinemaPlus</span>
        </div>
        <h2 class="auth-form__title">Recuperar Contraseña</h2>
      </div>

      <p class="auth-form__subtitle">Ingresa tu correo electrónico para enviarte un enlace de recuperación.</p>

      <div id="alert-container">
        {{#if message}}
          <div class="auth-form__alert auth-form__alert--success">
            {{message}}
          </div>
        {{/if}}
        {{#if serverError}}
          <div class="auth-form__alert auth-form__alert--error">
            {{serverError}}
          </div>
        {{/if}}
      </div>

      <div class="auth-form__field">
        <label class="auth-form__label" for="forgot-email">Email</label>
        <input class="auth-form__input" type="email" id="forgot-email" placeholder="name@example.com" {{#if isLoading}}disabled{{/if}} />
        <span class="auth-form__error" id="err-forgot-email"></span>
      </div>

      <button class="auth-form__submit" type="submit" id="forgot-submit-btn" {{#if isLoading}}disabled{{/if}}>
        {{#if isLoading}}Enviando...{{else}}Enviar enlace{{/if}}
      </button>

      {{#if demoLink}}
        <div class="auth-form__field" style="margin-top: 1.5rem; text-align: center;">
          <a href="{{demoLink}}" data-navigate="{{demoLink}}" class="auth-form__submit" style="display: block; text-decoration: none;">
            Hacer clic para recuperar contraseña
          </a>
        </div>
      {{/if}}

      <div class="auth-form__footer">
        <a href="#" data-navigate="/login" class="auth-form__link">Volver al Login</a>
      </div>
    </form>
  </div>

  <div class="auth-layout__cover"></div>
</div>