<div class="home">

  {{#if isLoadingHero}}
    <section class="hero__skeleton"></section>
  {{else}}
    {{#if featuredMovie}}
      <section class="hero" style="background: linear-gradient(to top, #0f1115 5%, rgba(15, 17, 21, 0.4) 60%, #0f1115 95%), url({{featuredMovie.poster_url}}) center/cover no-repeat;">
        <div class="hero__content">
          <span class="hero__badge">ESTRENO DESTACADO</span>
          <h2 class="hero__title">{{featuredMovie.upperTitle}}</h2>
          <p class="hero__synopsis">{{featuredMovie.synopsis}}</p>
          <div class="hero__actions">
            <button class="hero__btn" data-navigate="/movie/{{featuredMovie.id}}">Ver Funciones Disponibles</button>
            {{#if featuredMovie.trailer_url}}
              <a href="{{featuredMovie.trailer_url}}" target="_blank" rel="noreferrer" class="hero__btn--trailer">
                Ver Tráiler
              </a>
            {{/if}}
          </div>
        </div>
      </section>
    {{/if}}
  {{/if}}

  {{#if showRecommendations}}
    <section class="recs">
      <div class="recs__header">
        <div>
          <h2 class="recs__title">{{recs.title}}</h2>
          {{#if recs.subtitle}}
            <p class="recs__subtitle">{{recs.subtitle}}</p>
          {{/if}}
        </div>

        <div class="recs__controls">
          <button class="recs__control-btn" id="recs-prev">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"></polyline></svg>
          </button>
          <button class="recs__control-btn" id="recs-next">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"></polyline></svg>
          </button>
        </div>
      </div>

      <div class="recs__carousel" id="recs-carousel">
        {{#each recs.items}}
          <div class="recs__card" data-navigate="/movie/{{this.id}}">
            <div class="recs__card-image-box">
              <button class="recs__card-dismiss-btn dismiss-btn" data-dismiss="{{this.id}}">&#10005;</button>
              <img src="{{this.poster_url}}" alt="{{this.title}}" class="recs__card-img" />
            </div>
            
            <div class="recs__card-panel">
              <span class="recs__card-reason-short {{#if ../recs.is_personalized}}recs__card-reason-short--personalized{{else}}recs__card-reason-short--generic{{/if}}">{{this.shortReason}}</span>
              <p class="recs__card-reason-long">{{this.reason}}</p>
            </div>
          </div>
        {{/each}}
      </div>
    </section>
  {{/if}}

  <div class="home__catalog">
    <section class="catalog-section" id="cartelera">
      <div class="catalog-header">
        <div class="catalog-header__info">
          <h2 class="catalog-header__title">Explorar Cartelera</h2>
          {{#unless isLoadingCatalog}}
            {{#unless fetchError}}
              <p class="catalog-header__subtitle">
                Mostrando {{totalMovies}} {{#if (eq totalMovies 1)}}película{{else}}películas{{/if}}
              </p>
            {{/unless}}
          {{/unless}}
        </div>
        
        <div class="catalog-filters">
          <select id="genre-select" class="catalog-filters__select {{#unless (eq selectedGenre 'Todas')}}catalog-filters__select--active{{/unless}}">
            {{#each dynamicGenres}}
              <option value="{{this}}" class="catalog-filters__option" {{#if (eq this ../selectedGenre)}}selected{{/if}}>
                {{#if (eq this 'Todas')}}Todos los Géneros{{else}}{{this}}{{/if}}
              </option>
            {{/each}}
          </select>
          <svg class="catalog-filters__icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"></polyline></svg>
        </div>
      </div>

      {{#if searchQuery}}
        <div class="catalog-search-results">
          Resultados para la búsqueda: <strong class="catalog-search-results__query">"{{searchQuery}}"</strong>
        </div>
      {{/if}}

      {{#if fetchError}}
        <div class="catalog-state">
          <div class="catalog-state__icon">🔌</div>
          <h2 class="catalog-state__title">{{fetchError}}</h2>
          <button class="catalog-state__btn" id="retry-btn">Reintentar</button>
        </div>
      {{else}}
        {{#if (and (not isLoadingCatalog) (not hasMovies))}}
          <div class="catalog-state catalog-state--empty">
            <div class="catalog-state__icon catalog-state__icon--empty">🔍</div>
            <h2 class="catalog-state__title catalog-state__title--empty">No encontramos películas para tu búsqueda.</h2>
            <p class="catalog-state__subtitle">Intenta probar con otros términos o limpia los filtros activos.</p>
            <button class="catalog-state__btn catalog-state__btn--primary" id="clear-filters-btn">Ver toda la cartelera</button>
          </div>
        {{else}}
          <div class="catalog-grid">
            {{#each movies}}
              <div class="movie-card" data-navigate="/movie/{{this.id}}" style="cursor: pointer;">
                <div class="movie-card__image-wrapper">
                  <div class="movie-card__badge-rating">{{this.rating_classification}}</div>
                  <img src="{{this.poster_url}}" alt="{{this.title}}" class="movie-card__image" loading="lazy" />
                  <div class="movie-card__overlay">
                    <p class="movie-card__overlay-synopsis">{{this.synopsis}}</p>
                    {{#if this.trailer_url}}
                      <button class="movie-card__btn-trailer" data-trailer="{{this.trailer_url}}">Ver Tráiler Oficial</button>
                    {{/if}}
                  </div>
                </div>
                
                <div class="movie-card__info">
                  <h3 class="movie-card__title" title="{{this.title}}">{{this.title}}</h3>
                  <span class="movie-card__genres">{{this.genreString}}</span>
                  
                  <div class="movie-card__footer-meta">
                    <div class="movie-card__duration">
                      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><polyline points="12 6 12 12 16 14"></polyline></svg>
                      {{this.durationString}}
                    </div>
                    <div class="movie-card__formats-tags">
                      <span class="movie-card__tag">2D</span>
                      <span class="movie-card__tag">DUB</span>
                    </div>
                  </div>
                </div>
              </div>
            {{/each}}
            
            {{#if isLoadingCatalog}}
              {{#each skeletons}}
                <div class="skeleton">
                  <div class="skeleton-img"></div>
                  <div class="skeleton-content">
                    <div class="skeleton-text medium"></div>
                    <div class="skeleton-text short"></div>
                  </div>
                </div>
              {{/each}}
            {{/if}}
          </div>
          
          {{#if hasMore}}
            <div class="catalog-footer">
              <button class="catalog-footer__btn" id="load-more-btn" {{#if isFetchingMore}}disabled{{/if}}>
                {{#if isFetchingMore}}Cargando...{{else}}Ver Más Películas{{/if}}
              </button>
            </div>
          {{/if}}
        {{/if}}
      {{/if}}
    </section>
  </div>
</div>