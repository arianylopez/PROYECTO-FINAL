<div class="auth-layout">
  <div class="auth-layout__sidebar">
    <form class="auth-form" id="login-form-element" novalidate>
      
      <div class="auth-form__header">
        <div class="auth-form__logo">
          <svg class="auth-form__logo-icon" width="28" height="28" viewBox="0 0 24 24" fill="currentColor">
            <path d="M22 10V6a2 2 0 0 0-2-2H4a2 2 0 0 0-2 2v4c1.1 0 2 .9 2 2s-.9 2-2 2v4a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2v-4c-1.1 0-2-.9-2-2s.9-2 2-2z"/>
          </svg>
          <span class="auth-form__logo-text">CinemaPlus</span>
        </div>
        <h2 class="auth-form__title">Sign In</h2>
      </div>

      <p class="auth-form__subtitle">{{subtitleText}}</p>

      <div id="login-alert-container">
        {{#if serverError}}
          <div class="auth-form__alert auth-form__alert--error">
            {{serverError}}
          </div>
        {{/if}}
      </div>

      <div class="auth-form__field">
        <label class="auth-form__label" for="login-email">Email</label>
        <input class="auth-form__input" type="email" id="login-email" placeholder="name@example.com" {{#if isLoading}}disabled{{/if}} />
        <span class="auth-form__error" id="err-login-email"></span>
      </div>

      <div class="auth-form__field">
        <label class="auth-form__label" for="login-password">Password</label>
        <div class="auth-form__password-wrapper">
          <input class="auth-form__input auth-form__input--password" type="password" id="login-password" placeholder="Enter your password" {{#if isLoading}}disabled{{/if}} />
        </div>
        <span class="auth-form__error" id="err-login-password"></span>
      </div>

      <div class="auth-form__actions">
        <a href="#" data-navigate="/forgot-password" class="auth-form__link auth-form__link--forgot">¿Olvidaste tu contraseña?</a>
      </div>

      <button class="auth-form__submit" type="submit" id="login-submit-btn" {{#if isLoading}}disabled{{/if}}>
        {{#if isLoading}}Verificando...{{else}}Sign in{{/if}}
      </button>

      <div class="auth-form__divider">OR</div>

      <button type="button" class="auth-form__google-btn" id="log-google-btn" {{#if isGoogleLoading}}disabled{{/if}}>
        <svg class="auth-form__google-icon" width="18" height="18" viewBox="0 0 24 24">
          <path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"/>
          <path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/>
          <path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"/>
          <path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/>
        </svg>
        <span class="auth-form__google-text">
          {{#if isGoogleLoading}}Conectando...{{else}}Continuar con Google{{/if}}
        </span>
      </button>

      <div class="auth-form__footer">
        Don't have an account?
        <a href="#" data-navigate="/register" class="auth-form__link auth-form__link--signup">Sign Up</a>
      </div>
    </form>
  </div>

  <div class="auth-layout__cover"></div>

  <div id="modal-container">
    {{#if devicesLimit.length}}
      <div class="auth-modal-overlay">
        <div class="auth-modal">
          <h3 class="auth-modal__title auth-modal__title--danger">Límite de dispositivos (3/3)</h3>
          <p class="auth-modal__text">Revoca una sesión activa para ingresar desde este nuevo dispositivo.</p>
          
          {{#each devicesLimit}}
            <div class="auth-modal__item">
              <div>
                <strong class="auth-modal__item-title">{{this.name}}</strong>
                <span class="auth-modal__item-subtitle">Última vez: {{this.last_seen}}</span>
              </div>
              <button type="button" data-revoke-id="{{this.id}}" class="auth-modal__btn-revoke">Revocar</button>
            </div>
          {{/each}}
          
          <button type="button" data-close-modal="true" class="auth-modal__btn-cancel">Cancelar</button>
        </div>
      </div>
    {{/if}}

    {{#if showBirthModal}}
      <div class="auth-modal-overlay">
        <div class="auth-modal">
          <h3 class="auth-modal__title auth-modal__title--warn">¡Casi listo, {{pendingGoogleData.name}}!</h3>
          <p class="auth-modal__text">Para proteger a nuestra comunidad, necesitamos verificar tu edad antes de completar el registro.</p>
          
          {{#if modalError}}
            <div class="auth-form__alert auth-form__alert--error">{{modalError}}</div>
          {{/if}}
          
          <div class="auth-form__field">
            <label class="auth-form__label" for="modal-birthdate-input">Fecha de nacimiento</label>
            <input type="date" id="modal-birthdate-input" class="auth-form__input" value="{{birthDate}}" {{#if isGoogleLoading}}disabled{{/if}} />
          </div>

          <button type="button" id="finalizar-registro-btn" class="auth-form__submit" {{#if isGoogleLoading}}disabled{{/if}}>
            {{#if isGoogleLoading}}Procesando...{{else}}Finalizar registro{{/if}}
          </button>
          
          <button type="button" data-close-modal="true" class="auth-modal__btn-cancel">Cancelar</button>
        </div>
      </div>
    {{/if}}
  </div>
</div>