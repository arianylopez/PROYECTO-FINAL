<div class="movie-detail">
  
  {{#if isMovieLoading}}
    <div class="movie-detail__loading">
      Cargando película...
    </div>
  {{else}}
    {{#if error}}
      <div class="movie-detail__error">
        Película no encontrada o error de conexión.
      </div>
    {{else}}
      <div class="movie-detail__hero">
        <div class="movie-detail__hero-bg" style="background-image: url({{movie.poster_url}})"></div>
        <div class="movie-detail__hero-content">
          <img src="{{movie.poster_url}}" alt="{{movie.title}}" class="movie-detail__poster" />
          
          <div class="movie-detail__info">
            <h1 class="movie-detail__title">{{movie.title}}</h1>
            
            <div class="movie-detail__meta">
              <span class="movie-detail__meta-item">{{movie.director}}</span>
              <span class="movie-detail__meta-dot">•</span>
              <span class="movie-detail__meta-item">{{movie.duration_hours}}h {{movie.duration_mins}}m</span>
              <span class="movie-detail__meta-dot">•</span>
              <span class="movie-detail__meta-badge">{{movie.rating_classification}}</span>
            </div>

            <div class="movie-detail__genres">
              {{#each movie.genres}}
                <span class="movie-detail__genre">{{this}}</span>
              {{/each}}
            </div>

            <p class="movie-detail__synopsis">{{movie.synopsis}}</p>
            
            <div class="movie-detail__actions">
              <button class="movie-detail__btn" id="btn-buy-ticket">Comprar entradas</button>

              <button class="movie-detail__btn--secondary {{#if isWatchlisted}}active{{/if}}" id="btn-watchlist">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="{{#if isWatchlisted}}currentColor{{else}}none{{/if}}" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M19 21l-7-5-7 5V5a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2z"></path>
                </svg>
                {{#if isWatchlisted}}En Mi Lista{{else}}Añadir a Mi Lista{{/if}}
              </button>
            </div>
          </div>
        </div>
      </div>

      <div class="reviews-section">
        <h2 class="reviews-section__title">Opiniones de la Audiencia</h2>
        
        <div class="reviews-section__container">
          
          <div class="reviews-section__summary">
            
            <div class="reviews-section__stats">
              <div class="reviews-section__stats-score">
                {{reviewsStats.avg_score_formatted}}
              </div>
              <div class="reviews-section__stats-stars">
                {{{reviewsStats.stars_html}}}
              </div>
              <div class="reviews-section__stats-label">
                {{reviewsStats.sentiment_label}}
              </div>
              <div class="reviews-section__stats-total">Basado en {{reviewsStats.total_ratings}} calificaciones</div>
            </div>

            <div class="reviews-section__bars">
              
              <div class="reviews-section__bar-row">
                <span class="reviews-section__bar-label">Positivas</span>
                <div class="reviews-section__bar-track">
                  <div class="reviews-section__bar-fill reviews-section__bar-fill--pos" style="width: {{reviewsStats.posPct}}%;"></div>
                </div>
                <span class="reviews-section__bar-pct">{{reviewsStats.posPct}}%</span>
              </div>
              
              <div class="reviews-section__bar-row">
                <span class="reviews-section__bar-label">Neutrales</span>
                <div class="reviews-section__bar-track">
                  <div class="reviews-section__bar-fill reviews-section__bar-fill--neu" style="width: {{reviewsStats.neuPct}}%;"></div>
                </div>
                <span class="reviews-section__bar-pct">{{reviewsStats.neuPct}}%</span>
              </div>
              
              <div class="reviews-section__bar-row">
                <span class="reviews-section__bar-label">Negativas</span>
                <div class="reviews-section__bar-track">
                  <div class="reviews-section__bar-fill reviews-section__bar-fill--neg" style="width: {{reviewsStats.negPct}}%;"></div>
                </div>
                <span class="reviews-section__bar-pct">{{reviewsStats.negPct}}%</span>
              </div>

            </div>
          </div>

          <div class="reviews-section__form-container">
            <h3 class="reviews-section__form-title">Comparte tu experiencia</h3>
            
            {{#if user}}
              <form id="review-form" class="reviews-section__form">
                {{#if reviewErrorMsg}}
                  <div class="reviews-section__form-error">
                    ⚠️ {{reviewErrorMsg}}
                  </div>
                {{/if}}
                
                <div class="reviews-section__form-group">
                  <label class="reviews-section__form-label">Tu Calificación <span>*</span></label>
                  <div class="star-rating" role="radiogroup" aria-label="Calificar película">
                    {{{formStarsHtml}}}
                  </div>
                </div>

                <div class="reviews-section__form-group">
                  <label class="reviews-section__form-label">Tu Reseña <span class="optional">(Opcional)</span></label>
                  <textarea 
                    id="review-textarea" 
                    placeholder="¿Qué te pareció la película? Escribe tu opinión aquí..."
                    maxlength="500"
                    rows="4"
                    class="reviews-section__form-textarea"
                  >{{reviewText}}</textarea>
                  <div class="reviews-section__form-count">
                    <span id="review-char-count">{{reviewTextLength}}</span> / 500
                  </div>
                </div>

                <div class="reviews-section__form-actions">
                  <button 
                    type="submit" 
                    id="submit-review-btn"
                    {{#if isSubmitting}}disabled{{/if}}
                    class="reviews-section__form-submit"
                  >
                    {{#if isSubmitting}}Procesando...{{else}}Publicar{{/if}}
                  </button>
                </div>
              </form>
            {{else}}
              <div class="reviews-section__form-login">
                <p>Debes iniciar sesión para calificar y publicar una reseña.</p>
                <button id="login-prompt-btn" class="reviews-section__form-btn">
                  Iniciar Sesión
                </button>
              </div>
            {{/if}}
          </div>

          <div>
            <div class="reviews-section__filters">
              <button class="review-filter-btn reviews-section__filter-btn {{#if (eq reviewFilter 'ALL')}}reviews-section__filter-btn--active{{/if}}" data-filter="ALL">Todas ({{reviewsStats.total_all}})</button>
              <button class="review-filter-btn reviews-section__filter-btn {{#if (eq reviewFilter 'POSITIVE')}}reviews-section__filter-btn--active{{/if}}" data-filter="POSITIVE">Positivas ({{reviewsStats.total_pos}})</button>
              <button class="review-filter-btn reviews-section__filter-btn {{#if (eq reviewFilter 'NEUTRAL')}}reviews-section__filter-btn--active{{/if}}" data-filter="NEUTRAL">Neutrales ({{reviewsStats.total_neu}})</button>
              <button class="review-filter-btn reviews-section__filter-btn {{#if (eq reviewFilter 'NEGATIVE')}}reviews-section__filter-btn--active{{/if}}" data-filter="NEGATIVE">Negativas ({{reviewsStats.total_neg}})</button>
            </div>

            {{#if (eq filteredReviews.length 0)}}
              <div class="reviews-section__empty">
                No hay reseñas escritas en esta categoría.
              </div>
            {{else}}
              <div class="reviews-section__grid">
                {{#each filteredReviews}}
                  <div class="review-card">
                    <div class="review-card__header">
                      <div class="review-card__user-info">
                        <div class="review-card__avatar">
                          {{this.first_letter}}
                        </div>
                        <div class="review-card__user-details">
                          <div class="review-card__username">{{this.user_name}}</div>
                          <div class="review-card__date">{{this.formatted_date}}</div>
                        </div>
                      </div>
                      <div class="review-card__stars">
                        {{{this.stars_html}}}
                      </div>
                    </div>
                    {{#if this.text}}
                      <p class="review-card__text">
                        {{this.display_text}}
                        {{#if this.isLong}}
                          <button class="review-card__toggle review-card__more-btn" data-review-id="{{this.id}}">
                            {{#if this.expanded}} Ver menos{{else}} Leer más{{/if}}
                          </button>
                        {{/if}}
                      </p>
                    {{/if}}
                  </div>
                {{/each}}
              </div>
            {{/if}}
          </div>

        </div>
      </div>
    {{/if}}
  {{/if}}
</div>