{{#if isLoading}}
  <div class="profile__loading">Cargando información...</div>
{{else}}
  <div class="profile">
    <div class="profile__container">
      
      <div class="profile__sidebar">
        <div class="profile__user">
          <div class="profile__avatar">
            {{userInitial}}
          </div>
          <div>
            <h3 class="profile__username">{{user.name}}</h3>
            <span class="profile__badge">Cinéfilo Activo</span>
          </div>
        </div>

        <nav class="profile__nav">
          <button id="tab-tickets" class="profile__nav-btn {{#if (eq activeTab 'tickets')}}profile__nav-btn--active{{/if}}">🎟️ Mis Entradas</button>
          <button id="tab-list" class="profile__nav-btn {{#if (eq activeTab 'list')}}profile__nav-btn--active{{/if}}">⭐ Mi Lista</button>
          <button id="tab-activity" class="profile__nav-btn {{#if (eq activeTab 'activity')}}profile__nav-btn--active{{/if}}">📊 Mi Actividad</button>
        </nav>
      </div>

      <div class="profile__content">
        
        {{#if (eq activeTab 'tickets')}}
          {{#if (eq orders.length 0)}}
            <div class="profile__empty">
              <div class="profile__empty-icon">🎬</div>
              <h2 class="profile__empty-title">No tienes entradas aún</h2>
              <button id="btn-explore" class="profile__empty-btn">Explorar Cartelera</button>
            </div>
          {{else}}
            <div class="tickets__layout">
              <div class="tickets__list-container" style="flex: {{#if selectedOrder}}1{{else}}100%{{/if}}">
                <h2 class="profile__title">Mis Entradas</h2>
                
                {{#if upcomingOrders.length}}
                  <div style="margin-bottom: 3rem;">
                    <h3 class="tickets__section-title">Próximas Funciones</h3>
                    <div class="tickets__list">
                      {{#each upcomingOrders}}
                        <div class="ticket-card {{#if this.selected}}ticket-card--active{{/if}}" data-id="{{this.id}}">
                          <img src="{{this.poster_url}}" class="ticket-card__poster" alt="Poster" />
                          <div class="ticket-card__info">
                            <div class="ticket-card__header">
                              <h4 class="ticket-card__title">{{this.movie_title}}</h4>
                              <span class="ticket-card__status">PRÓXIMO</span>
                            </div>
                            <p class="ticket-card__text">{{this.formattedDate}}</p>
                            <p class="ticket-card__text ticket-card__text--muted">{{this.room_name}} • Asientos: {{this.seatLabelsStr}}</p>
                          </div>
                        </div>
                      {{/each}}
                    </div>
                  </div>
                {{/if}}

                {{#if pastOrders.length}}
                  <div>
                    <h3 class="tickets__section-title">Historial</h3>
                    <div class="tickets__list">
                      {{#each pastOrders}}
                        <div class="ticket-card ticket-card--past {{#if this.selected}}ticket-card--active{{/if}}" data-id="{{this.id}}">
                          <img src="{{this.poster_url}}" class="ticket-card__poster ticket-card__poster--past" alt="Poster" />
                          <div class="ticket-card__info">
                            <div class="ticket-card__header">
                              <h4 class="ticket-card__title">{{this.movie_title}}</h4>
                              <span class="ticket-card__status ticket-card__status--past">FINALIZADA</span>
                            </div>
                            <p class="ticket-card__text ticket-card__text--muted">{{this.formattedDate}}</p>
                          </div>
                        </div>
                      {{/each}}
                    </div>
                  </div>
                {{/if}}
              </div>

              {{#if selectedOrder}}
                <div class="ticket-detail">
                  <div class="ticket-detail__hero">
                    <div class="ticket-detail__hero-bg" style="background-image: url('{{selectedOrder.poster_url}}');"></div>
                    <button id="btn-close-order" class="ticket-detail__close">✕</button>
                    <div class="ticket-detail__hero-content">
                      <h2 class="ticket-detail__title">{{selectedOrder.movie_title}}</h2>
                    </div>
                  </div>
                  <div class="ticket-detail__body">
                    <div class="ticket-detail__qr">
                      <img src="https://api.qrserver.com/v1/create-qr-code/?size=150x150&data={{selectedOrder.id}}" alt="QR" class="ticket-detail__qr-img" />
                    </div>
                    <div class="ticket-detail__section">
                      <h4 class="ticket-detail__section-title">Información de la Función</h4>
                      <div class="ticket-detail__grid">
                          <div><span class="ticket-detail__label">Fecha</span> {{selectedOrder.detailsDate}}</div>
                          <div><span class="ticket-detail__label">Hora</span> {{selectedOrder.detailsTime}}</div>
                          <div><span class="ticket-detail__label">Sala</span> {{selectedOrder.room_name}}</div>
                          <div><span class="ticket-detail__label">Asientos ({{selectedOrder.seat_labels.length}})</span> <strong class="ticket-detail__highlight">{{selectedOrder.seatLabelsStr}}</strong></div>
                      </div>
                    </div>
                    <div class="ticket-detail__summary">
                      <h4 class="ticket-detail__section-title ticket-detail__section-title--muted">Resumen de Pago</h4>
                      <div class="ticket-detail__row"><span>Estado</span> <span class="ticket-detail__status-text">{{selectedOrder.status}}</span></div>
                      <div class="ticket-detail__row"><span>Orden</span> <span class="ticket-detail__id-text">{{selectedOrder.id}}</span></div>
                      <div class="ticket-detail__total-row">
                          <span>TOTAL</span>
                          <span>Bs. {{formatPrice selectedOrder.total_price}}</span>
                      </div>
                    </div>
                  </div>
                </div>
              {{/if}}
            </div>
          {{/if}}
        {{/if}}

        {{#if (eq activeTab 'list')}}
          <div>
            <h2 class="profile__title">Mi Lista</h2>
            {{#if (eq watchlist.length 0)}}
              <p class="profile__empty-text">No has guardado ninguna película.</p>
            {{else}}
              <div class="watchlist-grid">
                {{#each watchlist}}
                  <div class="watchlist-card" data-id="{{this.movie_id}}">
                    <img src="{{this.poster_url}}" alt="{{this.movie_title}}" class="watchlist-card__poster" />
                    <div class="watchlist-card__body"><h3 class="watchlist-card__title">{{this.movie_title}}</h3></div>
                    <button class="watchlist-card__remove" data-id="{{this.movie_id}}">
                      ✕
                    </button>
                  </div>
                {{/each}}
              </div>
            {{/if}}
          </div>
        {{/if}}

        {{#if (eq activeTab 'activity')}}
          <div class="activity__container">
            <h2 class="profile__title">Mi Actividad</h2>
            {{#if (eq activities.length 0)}}
              <p class="profile__empty-text">Aún no hay actividad registrada en tu cuenta.</p>
            {{else}}
              <div class="activity__timeline">
                <div class="activity__timeline-line"></div>
                {{#each activities}}
                  <div class="activity-item">
                    <div class="activity-item__dot" style="background-color: {{this.iconColor}};"></div>
                    <div class="activity-item__card">
                      <div class="activity-item__header">
                        <strong class="activity-item__title" style="color: {{this.iconColor}};">{{this.title}}</strong>
                        <span class="activity-item__date">{{this.formattedDate}}</span>
                      </div>
                      <p class="activity-item__desc">{{this.description}}</p>
                    </div>
                  </div>
                {{/each}}
              </div>
            {{/if}}
          </div>
        {{/if}}

      </div>
    </div>
  </div>
{{/if}}
