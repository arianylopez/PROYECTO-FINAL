{{#if isLoading}}
  <div class="payment-page__loading">Procesando...</div>
{{else}}
  <div class="payment-page">
    <div class="payment-page__bg-container">
      <div class="payment-page__bg-image" style="background-image: url('{{data.movie.poster_url}}');"></div>
    </div>

    <div class="payment-page__content">
      
      <div class="booking-steps">
        <div class="step step--inactive">
          <div class="step__dot"></div>
          Asientos
        </div>
        <div class="booking-steps__line"></div>
        <div class="step step--active">
          <div class="step__dot"></div>
          Pago
        </div>
        <div class="booking-steps__line"></div>
        <div class="step step--inactive">
          <div class="step__dot"></div>
          Entradas
        </div>
      </div>

      {{#if errorMsg}}
        <div class="payment-page__error">{{errorMsg}}</div>
      {{/if}}

      <div class="payment-layout">
        
        <div class="payment-info">
          <img src="{{data.movie.poster_url}}" class="payment-info__poster" alt="Poster" />
          <h2 class="payment-info__title">{{data.movie.title}}</h2>
          <div class="payment-info__meta">
            <span>{{durationHours}}h {{durationMins}}m</span> | <span class="payment-info__rating">{{data.movie.rating_classification}}</span>
          </div>

          <div class="payment-info__details">
            <div><strong class="payment-info__label">Fecha y Hora</strong> {{screenDateFormatted}}</div>
            <div><strong class="payment-info__label">Sala</strong> {{data.screening.room_name}}</div>
            <div><strong class="payment-info__label">Butacas Seleccionadas</strong> {{seatLabelsString}}</div>
          </div>
        </div>

        <div class="payment-form">
          <h2 class="payment-form__title">Método de pago</h2>
          
          <div class="payment-methods">
            <label class="payment-method {{#if (eq paymentMethod 'card')}}payment-method--active{{/if}}">
              <input type="radio" name="payment-method" value="card" {{#if (eq paymentMethod 'card')}}checked{{/if}} class="payment-method__input" /> Tarjeta
            </label>
            <label class="payment-method {{#if (eq paymentMethod 'qr')}}payment-method--active{{/if}}">
              <input type="radio" name="payment-method" value="qr" {{#if (eq paymentMethod 'qr')}}checked{{/if}} class="payment-method__input" /> Pago QR
            </label>
          </div>

          {{#if (eq paymentMethod 'card')}}
            <div class="card-form">
              <div class="card-form__group">
                <label class="card-form__label">Número de Tarjeta</label>
                <div class="card-form__input-wrapper">
                  <input type="text" id="card-number" placeholder="0000 0000 0000 0000" class="card-form__input" />
                  <span id="card-brand-display" class="card-form__brand">💳</span>
                </div>
                <span id="card-luhn-error" class="card-form__error-text" style="display: none;">Número de tarjeta inválido</span>
              </div>

              <div class="card-form__row">
                <div class="card-form__group">
                  <label class="card-form__label">Vencimiento (MM / AA)</label>
                  <div class="card-form__date-group">
                    <input type="text" id="card-month" placeholder="MM" class="card-form__input card-form__input--center" />
                    <input type="text" id="card-year" placeholder="AA" class="card-form__input card-form__input--center" />
                  </div>
                  <span id="card-expired-error" class="card-form__error-text" style="display: none;">La tarjeta está vencida</span>
                </div>
                <div class="card-form__group">
                  <label class="card-form__label">CVV</label>
                  <input type="password" id="card-cvv" placeholder="123" class="card-form__input" />
                </div>
              </div>

              <div class="card-form__group">
                <label class="card-form__label">Nombre del Titular</label>
                <input type="text" id="card-name" placeholder="COMO APARECE EN LA TARJETA" class="card-form__input card-form__input--uppercase" />
              </div>
            </div>
          {{/if}}

          {{#if (eq paymentMethod 'qr')}}
            <div class="qr-payment">
              <div class="qr-payment__code">
                <svg width="100%" height="100%" viewBox="0 0 100 100"><rect width="100%" height="100%" fill="#fff"/><rect x="10" y="10" width="30" height="30" fill="#000"/><rect x="60" y="10" width="30" height="30" fill="#000"/><rect x="10" y="60" width="30" height="30" fill="#000"/><path d="M15 15h20v20h-20zM65 15h20v20h-20zM15 65h20v20h-20zM45 10h10v10h-10zM45 25h10v35h-10zM10 45h35v10h-35zM60 45h30v10h-30zM80 60h10v30h-10zM45 70h30v10h-30zM60 85h15v5h-15z" fill="#000"/></svg>
              </div>
              <p class="qr-payment__text">Escanea este código con tu aplicación bancaria.</p>
              <h3 class="qr-payment__amount">Bs. {{formatPrice invoice.total}}</h3>
            </div>
          {{/if}}
        </div>

        <div class="payment-summary">
          <h3 class="payment-summary__title">Resumen</h3>
          
          <div class="payment-summary__section">
            <h4 class="payment-summary__section-title">Entradas</h4>
            {{#each invoice.tickets}}
              <div class="payment-summary__row">
                <span>{{this.name}} <span class="payment-summary__highlight">x{{this.qty}}</span></span>
              </div>
            {{/each}}
          </div>

          <div class="payment-summary__section">
            <h4 class="payment-summary__section-title">Butacas</h4>
            <span class="payment-summary__value">{{seatLabelsString}}</span>
          </div>

          <div class="payment-summary__breakdown">
            <div class="payment-summary__row"><span>Subtotal</span><span>Bs. {{formatPrice invoice.subtotal}}</span></div>
            <div class="payment-summary__row"><span>Impuestos (13%)</span><span>Bs. {{formatPrice invoice.tax}}</span></div>
            <div class="payment-summary__row"><span>Comisión servicio</span><span>Bs. {{formatPrice invoice.fee}}</span></div>
          </div>

          <div class="payment-summary__total-row">
            <span>Total</span>
            <span>Bs. {{formatPrice invoice.total}}</span>
          </div>

          <button 
            id="btn-pay"
            {{#if btnDisabled}}disabled{{/if}}
            class="payment-summary__btn {{#if btnDisabled}}payment-summary__btn--disabled{{else}}payment-summary__btn--active{{/if}}"
          >
            {{#if (eq paymentMethod 'card')}}Pagar Bs. {{formatPrice invoice.total}}{{else}}Confirmar pago QR{{/if}}
          </button>
        </div>

      </div>
    </div>
  </div>
{{/if}}
