{{#if isLoading}}
  <div class="screening-page__loading">Cargando funciones y cartelera...</div>
{{else}}
  {{#if fetchError}}
    <div class="screening-page__error">{{fetchError}}</div>
  {{else}}
    <div class="screening-page">
      
      <div class="movie-banner">
        <img src="{{movie.poster_url}}" alt="{{movie.title}}" class="movie-banner__poster" />
        <div>
          <h1 class="movie-banner__title">{{movie.title}}</h1>
          <div class="movie-banner__meta">
            <span class="movie-banner__rating">{{movie.rating_classification}}</span>
            <span>{{durationString}}</span>
          </div>
        </div>
      </div>

      <div class="date-slider">
        <button id="scroll-left-dates" class="date-slider__nav">&lsaquo;</button>
        <div class="date-slider__list" id="dates-container">
          {{#each availableDates}}
            <button 
              class="date-slider__btn {{#if (eq this ../selectedDate)}}date-slider__btn--active{{/if}}"
              data-date="{{this}}"
            >
              {{this}}
            </button>
          {{/each}}
        </div>
        <button id="scroll-right-dates" class="date-slider__nav">&rsaquo;</button>
      </div>

      <div class="formats-filter">
        {{#each formatsList}}
          <button 
            class="formats-filter__btn {{#if (eq this ../selectedFormat)}}formats-filter__btn--active{{/if}}"
            data-format="{{this}}"
          >
            {{this}}
          </button>
        {{/each}}
      </div>

      <div class="rooms-list">
        {{#if hasRooms}}
          {{#each rooms}}
            <div class="room-card">
              <div class="room-card__header">
                <h3 class="room-card__title">
                  {{roomName}}
                  <span class="room-card__format-badge">{{format}}</span>
                </h3>
                <div class="room-card__features">
                  <span>&check; Asientos Numerados</span>
                  <span>&check; Accesibilidad &#9855;</span>
                  <span>&check; {{language}}</span>
                </div>
              </div>

              <div class="room-card__times">
                  {{#each screenings}}
                    <button class="time-btn" data-id="{{id}}">
                      {{timeString}}
                    </button>
                  {{/each}}
              </div>
            </div>
          {{/each}}
        {{else}}
          <div class="rooms-list__empty">
            <p class="rooms-list__empty-text">No hay funciones que coincidan con los filtros seleccionados para este día.</p>
          </div>
        {{/if}}
      </div>

      <section class="upcoming-section">
        <div class="upcoming-section__header">
          <h2 class="upcoming-section__title">PRÓXIMAMENTE</h2>
          <span class="upcoming-section__link">Ver todas</span>
        </div>

        <div class="upcoming-slider">
          <div class="upcoming-slider__track" id="upcoming-slider">
            {{#each upcomingMovies}}
              <div class="upcoming-card" data-navigate="/movie/{{id}}">
                <img src="{{poster_url}}" alt="{{title}}" class="upcoming-card__poster" />
                <h4 class="upcoming-card__title">{{title}}</h4>
                <p class="upcoming-card__genres">{{genresString}}</p>
                <p class="upcoming-card__release">Estreno: {{releaseYear}}</p>
              </div>
            {{/each}}
          </div>
        </div>
      </section>

      <div id="ticket-modal-slot"></div>

    </div>
  {{/if}}
{{/if}}
