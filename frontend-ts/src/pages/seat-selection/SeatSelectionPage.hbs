{{#if isLoading}}
  <div class="seat-page__loading">Cargando experiencia...</div>
{{else}}
  {{#if errorMsgGlobal}}
    <div class="seat-page__error">Error cargando datos.</div>
  {{else}}
    <div class="seat-page">
      
      <div class="seat-page__bg-container">
        <div class="seat-page__bg-image" style="background-image: url('{{data.movie.poster_url}}');"></div>
        <div class="seat-page__bg-overlay"></div>
      </div>

      <div class="seat-page__content">
        
        {{#if hasActiveReservation}}
           <div class="reservation-alert">
              <div>
                 <h3 class="reservation-alert__title">¡Tienes una reserva pendiente!</h3>
                 <p class="reservation-alert__desc">El sistema ha recuperado tus asientos. Completa el pago antes de que expire la reserva.</p>
              </div>
              <div class="reservation-alert__actions">
                 <strong class="reservation-alert__timer" id="lock-timer-display">
                    {{lockTimerFormatted}}
                 </strong>
                 <button id="btn-cancel-reservation" class="reservation-alert__btn-cancel">
                   Cancelar Reserva
                 </button>
              </div>
           </div>
        {{/if}}

        <div class="booking-steps">
          <div class="step step--active">
            <div class="step__dot"></div>
            Selección de Asientos
          </div>
          <div class="booking-steps__line"></div>
          <div class="step step--inactive">
            <div class="step__dot"></div>
            Pago
          </div>
          <div class="booking-steps__line"></div>
          <div class="step step--inactive">
            <div class="step__dot"></div>
            Confirmación
          </div>
        </div>

        <div class="layout-grid">
          
          <div class="movie-poster-card">
            <img src="{{data.movie.poster_url}}" alt="{{data.movie.title}}" class="movie-poster-card__img" />
            
            <h1 class="movie-poster-card__title">{{data.movie.title}}</h1>
            
            <div class="movie-poster-card__meta">
              <span>{{data.movie.durationHours}}h {{data.movie.durationMins}}m</span>
              <span>|</span>
              <span class="movie-poster-card__rating">{{data.movie.rating_classification}}</span>
            </div>

            <div class="movie-poster-card__session">
              <p class="movie-poster-card__room">{{data.screening.room_name}</p>
              <h3 class="movie-poster-card__date">
                {{screenDateString}}
              </h3>
              <h2 class="movie-poster-card__time">
                {{screenTimeString}}
              </h2>
            </div>
          </div>

          <div class="seat-map-section">
            
            <div class="seat-map-section__screen">
              PANTALLA
            </div>

            <div class="seat-grid">
              {{#each renderRows}}
                <div class="seat-row">
                  <div class="seat-row__label seat-row__label--left">{{this.row}}</div>
                  
                  <div class="seat-row__seats">
                    {{#each this.seats}}
                      {{#if this.isCorridor}}
                        <div class="seat-item seat-item--corridor"></div>
                      {{else}}
                        <div class="seat-item" data-id="{{this.id}}" title="{{../row}}-{{this.col}}" style="background-color: {{this.bgColor}}; border: {{#if this.borderColor}}2px solid {{this.borderColor}}{{else}}none{{/if}}; cursor: {{this.cursor}}; color: {{this.fontColor}}; opacity: {{this.opacity}};">
                          {{#if this.showLabel}}{{this.col}}{{/if}}
                        </div>
                      {{/if}}
                    {{/each}}
                  </div>
                  
                  <div class="seat-row__label seat-row__label--right">{{this.row}}</div>
                </div>
              {{/each}}
            </div>

            <div class="seat-legend">
              <div class="seat-legend__item"><div class="seat-legend__box seat-legend__box--available"></div> Disponible</div>
              <div class="seat-legend__item"><div class="seat-legend__box seat-legend__box--locked"></div> En proceso (Otro)</div>
              <div class="seat-legend__item"><div class="seat-legend__box seat-legend__box--selected"></div> Tu Reserva</div>
              <div class="seat-legend__item"><div class="seat-legend__box seat-legend__box--sold"></div> Ocupado</div>
            </div>
          </div>

          <div class="booking-summary">
            
            {{#if errorMsg}}
               <div class="booking-summary__error">
                 {{errorMsg}}
               </div>
            {{/if}}

            <h3 class="booking-summary__title">Boletos seleccionados</h3>
            
            <div class="booking-summary__items">
              {{#each purchaseSummary.items}}
                <div class="booking-summary__item">
                  <span class="booking-summary__item-name">{{this.name}} <span class="booking-summary__item-qty">x{{this.qty}}</span></span>
                  <span class="booking-summary__item-total">Bs. {{formatPrice this.total}}</span>
                </div>
              {{/each}}
            </div>

            <h3 class="booking-summary__title">Asientos seleccionados</h3>
            <div class="booking-summary__seats">
              {{#if selectedSeats.length}}
                {{#each selectedSeats}}
                  <span class="booking-summary__seat-badge">
                    {{this.row}}{{this.col}}{{#unless @last}},{{/unless}}
                  </span>
                {{/each}}
              {{else}}
                <span class="booking-summary__no-seats">Aún no has seleccionado asientos.</span>
              {{/if}}
            </div>

            <div class="booking-summary__total-row">
              <span class="booking-summary__total-label">Total a pagar:</span>
              <span class="booking-summary__total-val">Bs. {{formatPrice purchaseSummary.totalPrice}}</span>
            </div>

            <div class="booking-summary__actions">
              {{#if hasActiveReservation}}
                 <button 
                  id="btn-continue-payment"
                  class="btn-primary">
                  Retomar Pago
                </button>
              {{else}}
                <button 
                  id="btn-lock-seats"
                  {{#unless canContinue}}disabled{{/unless}}
                  class="btn-primary">
                  Continuar
                </button>
              {{/if}}
              
              <button 
                id="btn-go-back"
                class="btn-secondary">
                {{#if hasActiveReservation}}Volver{{else}}Cancelar{{/if}}
              </button>
            </div>

          </div>
        </div>

      </div>
    </div>
  {{/if}}
{{/if}}
