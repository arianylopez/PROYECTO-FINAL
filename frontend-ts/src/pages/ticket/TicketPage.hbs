{{#if purchaseData}}
  <div class="ticket-page">
    
    <div class="ticket-page__bg-container">
      <div class="ticket-page__bg-image" style="background-image: url('{{purchaseData.data.movie.poster_url}}');"></div>
      <div class="ticket-page__bg-overlay"></div>
    </div>

    <div class="ticket-page__content">
      
      <div class="booking-steps">
        <div class="step step--inactive">
          <div class="step__dot"></div>
          Selección de Asientos
        </div>
        <div class="booking-steps__line"></div>
        <div class="step step--inactive">
          <div class="step__dot"></div>
          Pago
        </div>
        <div class="booking-steps__line"></div>
        <div class="step step--active">
          <div class="step__dot"></div>
          Entradas
        </div>
      </div>

      <div class="success-header">
        <div class="success-header__icon">✓</div>
        <h1 class="success-header__title">¡Compra realizada con éxito!</h1>
        <p class="success-header__desc">Tus entradas han sido generadas y enviadas a tu correo.</p>
      </div>

      <div class="ticket-grid">
        
        <div class="ticket-visual-wrapper">
          <div class="ticket-visual">
            
            <div class="ticket-visual__hero">
              <div class="ticket-visual__hero-bg" style="background-image: url('{{purchaseData.data.movie.poster_url}}');"></div>
              <div class="ticket-visual__hero-content">
                <span class="ticket-visual__badge">Entrada Digital</span>
                <h2 class="ticket-visual__movie-title">{{purchaseData.data.movie.title}}</h2>
              </div>
            </div>

            <div class="ticket-visual__body">
              <div class="ticket-visual__cutout-left"></div>
              <div class="ticket-visual__cutout-right"></div>
              <div class="ticket-visual__dash-line"></div>

              <div class="ticket-visual__grid">
                <div>
                  <span class="ticket-visual__label">Fecha</span>
                  <strong class="ticket-visual__val">{{screenDateFormatted}}</strong>
                </div>
                <div style="text-align: right;">
                  <span class="ticket-visual__label">Hora</span>
                  <strong class="ticket-visual__val">{{screenTimeFormatted}}</strong>
                </div>
              </div>

              <div class="ticket-visual__grid">
                <div>
                  <span class="ticket-visual__label">Sala</span>
                  <strong class="ticket-visual__val--highlight">{{purchaseData.data.screening.room_name}}</strong>
                </div>
                <div style="text-align: right;">
                  <span class="ticket-visual__label">Asientos ({{purchaseData.invoice.totalTickets}})</span>
                  <strong class="ticket-visual__val--highlight">{{seatsLabelsString}}</strong>
                </div>
              </div>

              <div class="ticket-visual__qr-container">
                <img 
                  src="https://api.qrserver.com/v1/create-qr-code/?size=180x180&data={{purchaseData.res.order_id}}" 
                  alt="QR Access Code" 
                  class="ticket-visual__qr" 
                />
              </div>
              <div class="ticket-visual__order-info">
                <span class="ticket-visual__label">Número de Orden</span>
                <span class="ticket-visual__order-id">{{purchaseData.res.order_id}}</span>
              </div>

            </div>
          </div>
        </div>

        <div class="ticket-receipt">
          
          <h3 class="ticket-receipt__title">Resumen de la Transacción</h3>

          <div class="ticket-receipt__section">
            <h4 class="ticket-receipt__section-title">Información del Comprador</h4>
            <div class="ticket-receipt__grid">
              <div><span class="ticket-receipt__label">Nombre</span> {{#if user}}{{user.name}}{{else}}Usuario CinemaPlus{{/if}}</div>
              <div><span class="ticket-receipt__label">Email</span> {{#if user}}{{user.email}}{{else}}usuario@correo.com{{/if}}</div>
            </div>
          </div>

          <div class="ticket-receipt__section">
            <h4 class="ticket-receipt__section-title">Detalles de Función</h4>
            <ul class="ticket-receipt__list">
              <li><strong class="ticket-receipt__list-label">Película:</strong> {{purchaseData.data.movie.title}}</li>
              <li><strong class="ticket-receipt__list-label">Asientos:</strong> {{seatsLabelsString}}</li>
              <li><strong class="ticket-receipt__list-label">Entradas:</strong> {{ticketsString}}</li>
            </ul>
          </div>

          <div class="ticket-receipt__breakdown">
            <h4 class="ticket-receipt__section-title">Detalle de Pago</h4>
            <div class="ticket-receipt__totals">
              <div class="ticket-receipt__row"><span>Subtotal</span><span>Bs. {{formatPrice purchaseData.invoice.subtotal}}</span></div>
              <div class="ticket-receipt__row"><span>Comisión de servicio</span><span>Bs. {{formatPrice purchaseData.invoice.fee}}</span></div>
              <div class="ticket-receipt__row"><span>Impuestos de ley</span><span>Bs. {{formatPrice purchaseData.invoice.tax}}</span></div>
              <div class="ticket-receipt__row"><span>Método de Pago</span><span class="ticket-receipt__val-method">{{purchaseData.res.method}}</span></div>
            </div>
            <div class="ticket-receipt__final">
              <span>TOTAL PAGADO</span>
              <span class="ticket-receipt__final-val">Bs. {{formatPrice purchaseData.invoice.total}}</span>
            </div>
          </div>

          <div style="display: flex; flex-direction: column; gap: 1rem;">
            <button id="btn-go-home" class="ticket-receipt__btn">
              Volver al Catálogo
            </button>
          </div>

        </div>

      </div>

    </div>
  </div>
{{else}}
  <div class="ticket-page"></div>
{{/if}}
