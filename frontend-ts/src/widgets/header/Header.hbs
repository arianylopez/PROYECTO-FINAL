<header class="header">
  
  <div class="header__pill">
    <div class="header__logo" data-navigate="/home" title="Ir al Inicio">
      CINEMAPLUS
    </div>
  </div>

  <div class="header__pill">
    <div class="header__search">
      <button class="header__icon-btn" id="toggle-search" title="Buscar películas">
        <svg fill="none" stroke="currentColor" viewBox="0 0 24 24" width="20" height="20"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" /></svg>
      </button>
      <form id="search-form" class="header__search-form" style="width: {{#if isSearchOpen}}220px{{else}}0{{/if}}; opacity: {{#if isSearchOpen}}1{{else}}0{{/if}};">
        <input 
          id="search-input"
          type="text" 
          placeholder="Buscar en cartelera..." 
          value="{{searchQuery}}"
          class="header__search-input"
        />
      </form>
    </div>

    <div class="header__divider"></div>

    {{#if isAuthenticated}}
      <div class="header__user-menu" id="user-menu-container">
        <button class="header__user-btn" id="toggle-dropdown">
          <div class="header__avatar">
            {{user.first_letter}}
          </div>
          <span>{{user.first_name}}</span>
          <svg class="header__arrow {{#if isDropdownOpen}}header__arrow--open{{/if}}" fill="none" stroke="currentColor" viewBox="0 0 24 24" width="16" height="16"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M19 9l-7 7-7-7" /></svg>
        </button>

        <div class="header__dropdown {{#if isDropdownOpen}}header__dropdown--active{{/if}}" id="dropdown-menu">
          <div class="header__dropdown-header">
            <strong class="header__dropdown-name">{{user.name}}</strong>
            <span class="header__dropdown-email">{{user.email}}</span>
          </div>
          
          <button class="header__dropdown-item" data-navigate="/me/orders?tab=tickets">
            <svg fill="none" stroke="currentColor" viewBox="0 0 24 24" width="18" height="18"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 5v2m0 4v2m0 4v2M5 5a2 2 0 00-2 2v3a2 2 0 110 4v3a2 2 0 002 2h14a2 2 0 002-2v-3a2 2 0 110-4V7a2 2 0 00-2-2H5z" /></svg>
            Mis Entradas
          </button>
          
          <button class="header__dropdown-item" data-navigate="/me/orders?tab=list">
            ⭐ Mi Lista
          </button>

          <button class="header__dropdown-item" data-navigate="/me/orders?tab=activity">
            <svg fill="none" stroke="currentColor" viewBox="0 0 24 24" width="18" height="18"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" /></svg>
            Mi Actividad
          </button>

          <div class="header__dropdown-divider"></div>
          
          <button class="header__dropdown-item header__dropdown-item--logout" id="nav-logout">
            <svg fill="none" stroke="currentColor" viewBox="0 0 24 24" width="18" height="18"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1" /></svg>
            Cerrar Sesión
          </button>
        </div>
      </div>
    {{else}}
      <nav class="header__desktop-nav">
        <button class="header__nav-item" data-navigate="/register">Registro Rápido</button>
      </nav>
      <button class="header__login-btn" data-navigate="/login">Ingresar</button>
    {{/if}}

    <button class="header__mobile-toggle" id="toggle-mobile-nav">
      {{#if isMobileMenuOpen}}
        <svg fill="none" stroke="currentColor" viewBox="0 0 24 24" width="24" height="24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M6 18L18 6M6 6l12 12" /></svg>
      {{else}}
        <svg fill="none" stroke="currentColor" viewBox="0 0 24 24" width="24" height="24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M4 6h16M4 12h16M4 18h16" /></svg>
      {{/if}}
    </button>
  </div>

  <nav class="header__mobile-nav {{#if isMobileMenuOpen}}header__mobile-nav--active{{/if}}">
    {{#if isAuthenticated}}
      <div class="header__mobile-user-info">
        <div class="header__avatar">{{user.first_letter}}</div>
        <span>{{user.name}}</span>
      </div>
      <button class="header__mobile-link" data-navigate="/me/orders?tab=tickets">Mis Entradas</button>
      <button class="header__mobile-link" data-navigate="/me/orders?tab=list">⭐ Mi Lista</button>
      <button class="header__mobile-link" data-navigate="/me/orders?tab=activity">Mi Actividad</button>
      <div class="header__dropdown-divider"></div>
      <button class="header__mobile-link header__dropdown-item--logout" id="nav-logout">Cerrar Sesión</button>
    {{else}}
      <button class="header__mobile-link" data-navigate="/login">Ingresar</button>
      <button class="header__mobile-link" data-navigate="/register">Crear Cuenta</button>
    {{/if}}
  </nav>
</header>