<header class="header-wrapper">
  
  <div class="header-pill">
    <div class="logo" data-navigate="/home" title="Ir al Inicio">
      CINEMAPLUS
    </div>
  </div>

  <div class="header-pill">
    <div class="search-wrapper">
      <button class="icon-btn" id="toggle-search" title="Buscar películas">
        <svg fill="none" stroke="currentColor" viewBox="0 0 24 24" width="20" height="20"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" /></svg>
      </button>
      <form id="search-form" style="width: {{#if isSearchOpen}}220px{{else}}0{{/if}}; opacity: {{#if isSearchOpen}}1{{else}}0{{/if}}; transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1); overflow: hidden; display: flex;">
        <input 
          id="search-input"
          type="text" 
          placeholder="Buscar en cartelera..." 
          value="{{searchQuery}}"
          class="search-input"
        />
      </form>
    </div>

    <div class="divider"></div>

    {{#if isAuthenticated}}
      <div class="user-menu-container" id="user-menu-container">
        <button class="user-profile-btn" id="toggle-dropdown">
          <div class="avatar">
            {{user.first_letter}}
          </div>
          <span>{{user.first_name}}</span>
          <svg class="arrow {{#if isDropdownOpen}}open{{/if}}" fill="none" stroke="currentColor" viewBox="0 0 24 24" width="16" height="16"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M19 9l-7 7-7-7" /></svg>
        </button>

        <div class="dropdown-menu {{#if isDropdownOpen}}active{{/if}}" id="dropdown-menu">
          <div style="padding: 0.8rem 1.2rem; border-bottom: 1px solid #262932; margin-bottom: 0.5rem;">
            <strong style="color: #fff; display: block; font-size: 0.95rem;">{{user.name}}</strong>
            <span style="color: #9ca3af; font-size: 0.8rem;">{{user.email}}</span>
          </div>
          
          <button class="dropdown-item" data-navigate="/history">
            <svg fill="none" stroke="currentColor" viewBox="0 0 24 24" width="18" height="18"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 5v2m0 4v2m0 4v2M5 5a2 2 0 00-2 2v3a2 2 0 110 4v3a2 2 0 002 2h14a2 2 0 002-2v-3a2 2 0 110-4V7a2 2 0 00-2-2H5z" /></svg>
            Mis Tickets
          </button>
          
          <button class="dropdown-item" data-navigate="/preferences">
            <svg fill="none" stroke="currentColor" viewBox="0 0 24 24" width="18" height="18"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" /></svg>
            Preferencias
          </button>

          <div class="dropdown-divider"></div>
          
          <button class="dropdown-item logout" id="nav-logout">
            <svg fill="none" stroke="currentColor" viewBox="0 0 24 24" width="18" height="18"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1" /></svg>
            Cerrar Sesión
          </button>
        </div>
      </div>
    {{else}}
      <nav class="desktop-nav">
        <button class="nav-item" data-navigate="/register">Registro Rápido</button>
      </nav>
      <button class="login-btn" data-navigate="/login">Ingresar</button>
    {{/if}}

    <button class="mobile-toggle" id="toggle-mobile-nav">
      {{#if isMobileMenuOpen}}
        <svg fill="none" stroke="currentColor" viewBox="0 0 24 24" width="24" height="24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M6 18L18 6M6 6l12 12" /></svg>
      {{else}}
        <svg fill="none" stroke="currentColor" viewBox="0 0 24 24" width="24" height="24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M4 6h16M4 12h16M4 18h16" /></svg>
      {{/if}}
    </button>
  </div>

  <nav class="mobile-nav {{#if isMobileMenuOpen}}active{{/if}}">
    {{#if isAuthenticated}}
      <div class="mobile-user-info">
        <div class="avatar">{{user.first_letter}}</div>
        <span>{{user.name}}</span>
      </div>
      <button class="mobile-nav-link" data-navigate="/history">Mis Tickets</button>
      <button class="mobile-nav-link" data-navigate="/preferences">Preferencias</button>
      <div class="dropdown-divider"></div>
      <button class="mobile-nav-link" id="nav-logout" style="color: #ef4444;">Cerrar Sesión</button>
    {{else}}
      <button class="mobile-nav-link" data-navigate="/login">Ingresar</button>
      <button class="mobile-nav-link" data-navigate="/register">Crear Cuenta</button>
    {{/if}}
  </nav>
</header>